/* ===== MEASURE SAVE SHEET ===== */
.msr-save-sheet{position:absolute;inset:0;z-index:950;display:none;align-items:flex-end;background:rgba(0,0,0,.30);backdrop-filter:blur(8px)}
.msr-save-sheet.show{display:flex}
.msr-save-card{width:100%;max-width:640px;margin:0 auto;max-height:94dvh;overflow-y:auto;overscroll-behavior:contain;border-radius:28px 28px 0 0;background:linear-gradient(180deg,#0d1929,#071120);border:1px solid rgba(255,255,255,.09);border-bottom:0;box-shadow:0 -28px 60px rgba(0,0,0,.48);padding:8px 16px calc(16px + var(--safe-bottom));color:#fff}
.msr-save-card::-webkit-scrollbar{width:0}
.msr-card-handle{width:44px;height:4px;border-radius:999px;background:rgba(255,255,255,.18);margin:0 auto 12px}
/* Section header inside save card */
.msr-sec{margin-top:12px}
.msr-sec-lbl{font-size:9px;font-weight:950;letter-spacing:1px;color:#5a7896;margin-bottom:5px;display:block}
/* Data rows */
.msr-data-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px}
.msr-data-cell{padding:8px 11px;border-radius:11px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.06)}
.msr-data-cell span{display:block;font-size:9px;font-weight:950;letter-spacing:.6px;color:#5a7896;margin-bottom:2px}
.msr-data-cell b{font-size:14px;font-weight:950;color:#fff}
.msr-data-cell b.yellow{color:#ffca18}
/* Coord display */
.msr-coord-box{padding:9px 12px;border-radius:11px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.06);font-size:12px;font-weight:850;color:#7ab3d4;letter-spacing:.2px;margin-bottom:2px}
/* Input inside save card */
.msr-field{width:100%;border:0;border-radius:11px;background:rgba(255,255,255,.07);color:#fff;min-height:40px;padding:0 12px;font-weight:850;outline:0;font-size:13px;font-family:inherit;border:1px solid rgba(255,255,255,.06)}
.msr-field::placeholder{color:rgba(140,168,195,.45)}
.msr-textarea{padding:9px 12px;min-height:56px;resize:none}
/* Glowing stat highlight */
.msr-highlight-stat{display:flex;align-items:center;justify-content:space-between;padding:10px 13px;border-radius:13px;background:linear-gradient(135deg,rgba(255,202,24,.10),rgba(255,202,24,.04));border:1px solid rgba(255,202,24,.20);margin-bottom:8px}
.msr-highlight-stat .msr-hl-lbl{font-size:10px;font-weight:950;letter-spacing:.6px;color:#8ea4bb}
.msr-highlight-stat .msr-hl-val{font-size:16px;font-weight:950;color:#ffca18;letter-spacing:-.3px}
/* Color swatch row (reuse .pc-*) */
/* Line style / width (reuse .ls-*, .lw-*) */
/* Save / Cancel */
.msr-save-btn{width:100%;height:50px;border:0;border-radius:14px;background:linear-gradient(180deg,#ffe27b,#ffca18);color:#111;font-weight:950;font-size:14px;margin-top:14px;letter-spacing:.3px;box-shadow:0 10px 24px rgba(255,202,24,.22)}
.msr-cancel-btn{width:100%;height:38px;border:0;background:transparent;color:#637c96;font-weight:900;font-size:12px;margin-top:4px}
/* Result badge on map */
.msr-result-badge{background:rgba(7,13,24,.88);color:#ffca18;border:1px solid rgba(255,202,24,.30);border-radius:10px;padding:4px 10px;font-size:12px;font-weight:950;pointer-events:none}
.msr-result-badge::before{display:none}
/* Tag attached to saved result polygon */
.msr-ha-lbl{background:rgba(7,13,24,.82);color:#ffe27b;border:1px solid rgba(255,202,24,.25);border-radius:8px;padding:3px 8px;font-size:11px;font-weight:950;pointer-events:none;white-space:nowrap}
.msr-ha-lbl::before{display:none}

/* ===== TRACKING PANEL — Ultra Premium Glass ===== */
.trk-ready-bar{position:absolute;left:0;right:0;bottom:0;z-index:850;display:none;flex-direction:column;background:none;padding:16px 16px calc(16px + var(--safe-bottom));pointer-events:none}
.trk-ready-bar.show{display:flex}
.trk-ready-inner{max-width:560px;margin:0 auto;width:100%;padding:16px 18px;border-radius:24px;background:linear-gradient(180deg,rgba(8,16,29,.82),rgba(8,16,29,.70));border:1px solid rgba(255,255,255,.08);box-shadow:0 18px 42px rgba(0,0,0,.22);backdrop-filter:blur(18px) saturate(150%);-webkit-backdrop-filter:blur(18px) saturate(150%);pointer-events:auto}
.trk-ready-title{font-size:10px;font-weight:950;letter-spacing:1.8px;color:#ffca18;margin-bottom:4px;text-transform:uppercase}
.trk-ready-sub{font-size:11px;color:rgba(255,255,255,.72);font-weight:760;margin-bottom:14px;line-height:1.45}
.trk-ready-btns{display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center}
.trk-mulai-btn{height:56px;border:0;border-radius:18px;background:linear-gradient(135deg,#ffca18 0%,#ffb300 100%);color:#0a0800;font-size:14px;font-weight:950;letter-spacing:.45px;display:flex;align-items:center;justify-content:center;gap:9px;box-shadow:0 12px 24px rgba(255,202,24,.24),inset 0 1px 0 rgba(255,255,255,.18)}
.trk-mulai-btn svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2.4;stroke-linecap:round}
.trk-tutup-btn{height:56px;min-width:74px;padding:0 14px;border:1px solid rgba(255,255,255,.10);border-radius:18px;background:rgba(255,255,255,.08);color:rgba(255,255,255,.82);font-size:11px;font-weight:900}
/* Active tracking HUD */
.trk-hud{position:absolute;left:0;right:0;bottom:0;z-index:851;display:none;flex-direction:column;background:none;padding:16px 16px calc(16px + var(--safe-bottom));pointer-events:none}
.trk-hud.show{display:flex}
.trk-hud-inner{max-width:560px;margin:0 auto;width:100%;padding:16px 18px;border-radius:24px;background:linear-gradient(180deg,rgba(8,16,29,.84),rgba(8,16,29,.72));border:1px solid rgba(255,255,255,.08);box-shadow:0 18px 42px rgba(0,0,0,.24);backdrop-filter:blur(18px) saturate(150%);-webkit-backdrop-filter:blur(18px) saturate(150%);pointer-events:auto}
/* Timer display */
.trk-timer-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.trk-timer{font-size:34px;font-weight:950;color:#ffca18;letter-spacing:-1px;font-variant-numeric:tabular-nums;text-shadow:0 0 20px rgba(255,202,24,.30)}
.trk-timer-lbl{font-size:8px;font-weight:950;letter-spacing:1.6px;color:rgba(255,202,24,.50);display:block;margin-bottom:1px;text-transform:uppercase}
.trk-hud-controls{display:flex;gap:8px;flex:none}
.trk-pause-btn,.trk-stop-btn{height:40px;border-radius:13px;border:0;font-size:11px;font-weight:950;letter-spacing:.4px;display:flex;align-items:center;justify-content:center;gap:6px;padding:0 16px}
.trk-pause-btn{background:rgba(255,255,255,.07);color:rgba(255,255,255,.75);border:1px solid rgba(255,255,255,.10)}
.trk-pause-btn svg,.trk-stop-btn svg{width:14px;height:14px;fill:currentColor}
.trk-stop-btn{background:rgba(224,69,69,.18);color:#ff9b9b;border:1px solid rgba(224,69,69,.28)}
/* Stats grid */
.trk-stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin-bottom:8px}
.trk-stat{padding:8px 6px;border-radius:12px;background:rgba(0,0,0,.40);border:1px solid rgba(255,202,24,.08);text-align:center;backdrop-filter:blur(8px)}
.trk-stat-lbl{font-size:7px;font-weight:950;letter-spacing:1px;color:rgba(255,202,24,.40);display:block;margin-bottom:3px;text-transform:uppercase}
.trk-stat-val{font-size:14px;font-weight:950;color:rgba(255,255,255,.90);white-space:nowrap}
/* GPS FIX indicator */
.trk-gps-bar{display:flex;align-items:center;gap:6px;padding:6px 12px;border-radius:11px;background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.06)}
.trk-gps-dot{width:8px;height:8px;border-radius:50%;background:#3ee08e;box-shadow:0 0 0 3px rgba(62,224,142,.18);flex:none;animation:pulseFix 1.4s ease-in-out infinite}
@keyframes pulseFix{0%,100%{box-shadow:0 0 0 3px rgba(62,224,142,.18)}50%{box-shadow:0 0 0 6px rgba(62,224,142,.08)}}
.trk-gps-dot.poor{background:#e05050;animation:none;box-shadow:0 0 0 3px rgba(224,80,80,.18)}
.trk-gps-dot.avg{background:#f0a000;box-shadow:0 0 0 3px rgba(240,160,0,.18)}
.trk-gps-text{font-size:10px;font-weight:950;color:rgba(255,255,255,.45);letter-spacing:.4px}
.trk-latlon{font-size:10px;font-weight:850;color:rgba(255,202,24,.35);margin-left:auto}

/* ===== TRACKING SAVE SHEET ===== */
.trk-save-sheet{position:absolute;inset:0;z-index:960;display:none;align-items:flex-end;background:rgba(0,0,0,.55);backdrop-filter:blur(12px)}
.trk-save-sheet.show{display:flex}
.trk-save-card{width:100%;max-width:640px;margin:0 auto;max-height:94dvh;overflow-y:auto;overscroll-behavior:contain;border-radius:28px 28px 0 0;background:linear-gradient(170deg,rgba(10,8,0,.96),rgba(4,4,0,.98));border:1px solid rgba(255,202,24,.12);border-bottom:0;box-shadow:0 -28px 60px rgba(0,0,0,.65);padding:8px 16px calc(16px + var(--safe-bottom));color:#fff}
.trk-save-card::-webkit-scrollbar{width:0}
.trk-card-handle{width:44px;height:4px;border-radius:999px;background:rgba(255,202,24,.25);margin:0 auto 12px}
/* Export chips */
.trk-export-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px}
.trk-export-chip{height:30px;padding:0 12px;border-radius:999px;border:1px solid rgba(255,202,24,.15);background:rgba(255,202,24,.05);color:rgba(255,202,24,.50);font-size:11px;font-weight:950;letter-spacing:.4px;cursor:pointer;display:flex;align-items:center;gap:5px;transition:background .14s,border-color .14s}
.trk-export-chip.sel{background:rgba(255,202,24,.16);border-color:rgba(255,202,24,.50);color:#ffca18}
.trk-export-chip svg{width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round}
/* Tracking route polyline badge */
.trk-route-lbl{background:rgba(0,0,0,.84);color:#ffca18;border:1px solid rgba(255,202,24,.25);border-radius:8px;padding:3px 8px;font-size:11px;font-weight:950;pointer-events:none;white-space:nowrap}
.trk-route-lbl::before{display:none}

@media(min-width:800px){
  .measure-panel,.msr-actions{width:min(360px,calc(100vw - 40px))}
  .trk-ready-inner,.trk-hud-inner{max-width:600px}
}
@media(max-width:560px){
  .measure-panel{top:calc(66px + var(--safe-top));width:min(330px,calc(100vw - 24px))}
  .msr-stat-row{grid-template-columns:1fr 88px;gap:7px}
  .msr-actions{width:min(330px,calc(100vw - 24px));bottom:calc(68px + var(--safe-bottom))}
  .msr-btn-row{gap:6px;padding:7px}
  .msr-done,.msr-undo,.msr-cancel{font-size:10.5px}
  .trk-ready-inner,.trk-hud-inner{padding:14px 14px 15px}
  .trk-ready-btns{grid-template-columns:1fr}
  .trk-tutup-btn{width:100%;min-width:0}
}
</style>
